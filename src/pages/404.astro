---
import { Image } from 'astro:assets';
import MainLayout from '../layouts/MainLayout.astro';
import { getImages, getHeroImage, featuredCollectionId } from '../data/imageStore';
import siteConfig from '../../site.config.mjs';

const base = import.meta.env.BASE_URL;

// Backdrop: the last featured photo, so the 404 doesn't just repeat the home-page hero.
const featured = await getImages({ collection: featuredCollectionId });
const backdrop = featured.at(-1) ?? (await getHeroImage(siteConfig.heroImage));
---

<MainLayout
	title="Page Not Found"
	description="The page you were looking for doesn't exist."
>
	<section
		class="relative mt-[65px] flex min-h-[calc(100svh-65px)] items-center overflow-hidden bg-black"
	>
		{
			backdrop && (
				<Image
					src={backdrop.src}
					quality={80}
					format="webp"
					width={1600}
					height={Math.round((1600 / backdrop.src.width) * backdrop.src.height)}
					alt=""
					aria-hidden="true"
					loading="eager"
					class="absolute inset-0 h-full w-full object-cover opacity-35"
				/>
			)
		}
		<div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/70"></div>

		<div class="container-custom relative z-10 py-24 text-center">
			<p class="eyebrow">Error 404</p>
			<h1 class="mt-6 text-6xl font-bold text-white md:text-8xl">Out of frame</h1>
			<div class="mx-auto mt-8 h-px w-16 bg-white/30"></div>
			<p class="mx-auto mt-8 max-w-lg text-lg text-white/80">
				The page you were looking for doesn't exist — it may have moved, or perhaps it was
				never developed.
			</p>

			<div class="mt-12 flex flex-col items-center gap-4 md:flex-row md:justify-center">
				<a
					href={base}
					class="cta-link w-80 max-w-full border px-8 py-4 text-center text-white/90 transition-colors duration-300 hover:text-brand"
					style="border-color: hsl(240, 0%, 46%);"
				>
					Back Home <span class="cta-arrow">&rarr;</span>
				</a>
				<a
					href={`${base}collections`}
					class="cta-link w-80 max-w-full border px-8 py-4 text-center text-white/90 transition-colors duration-300 hover:text-brand"
					style="border-color: hsl(240, 0%, 46%);"
				>
					View Gallery <span class="cta-arrow">&rarr;</span>
				</a>
			</div>
		</div>
	</section>
</MainLayout>
