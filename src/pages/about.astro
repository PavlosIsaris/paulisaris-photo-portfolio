---
import MainLayout from '../layouts/MainLayout.astro';
import { Content as AboutPage } from '../content/about.md';
import JsonLd from '../components/JsonLd.astro';
import { profilePageSchema, breadcrumbSchema } from '../data/jsonld';
import siteConfig from '../../site.config.mjs';

const profileImage = siteConfig.profileImage;
const base = import.meta.env.BASE_URL;

const description =
	'Paul Isaris was born in Athens and works across photography, writing and music, seeking to give form to the unspoken. Read his bio and get in touch.';
---

<MainLayout title="About" description={description} image={`/images/${profileImage}`}>
	<JsonLd slot="head" schema={profilePageSchema(Astro.site)} />
	<JsonLd
		slot="head"
		schema={breadcrumbSchema(Astro.site, [
			{ name: 'Home', url: '/' },
			{ name: 'About', url: '/about' },
		])}
	/>

	<section class="pt-32 pb-20">
		<div class="container-custom">
			<div class="max-w-2xl mx-auto text-center mb-16">
				<h1 class="text-4xl md:text-5xl font-bold mb-4">About Me</h1>
			</div>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
				<div>
					<img
						src=`${base}images/${profileImage}`
						alt={`Portrait of ${siteConfig.owner}`}
						class="w-full h-auto rounded-lg shadow-lg border-8 my-4 border-white md:p-4"
						width="720"
						height="720"
					/>
				</div>

				<div class="prose text-gray-700 mb-6">
					<AboutPage />
				</div>
			</div>
		</div>
	</section>
</MainLayout>
