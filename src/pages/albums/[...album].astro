---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import { Image } from 'astro:assets';
import MainLayout from '../../layouts/MainLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import AlbumText from '../../components/AlbumText.astro';
import YouTubeLink from '../../components/YouTubeLink.astro';
import Flipbook from '../../components/Flipbook.astro';
import JsonLd from '../../components/JsonLd.astro';
import flipbooksData from '../../data/flipbooks.json';
import { getImages, getImageByPath } from '../../data/imageStore';
import { breadcrumbSchema, imageAlt, imageGallerySchema } from '../../data/jsonld';

const flipbooks = flipbooksData as Record<
	string,
	{ pages: number; width: number; height: number }
>;

export const getStaticPaths = (async () => {
	const albums = await getCollection('albums', ({ data }) =>
		import.meta.env.PROD ? !data.draft : true,
	);
	return albums.map((album) => ({
		params: { album: album.id },
		props: { album },
	}));
}) satisfies GetStaticPaths;

const { album } = Astro.props;
const {
	title,
	description,
	seoDescription,
	galleryCollection,
	cover: coverPath,
	videos,
	pdfs,
} = album.data;

const cover = await getImageByPath(coverPath);
const images = await getImages({ collection: galleryCollection });
const { Content } = await render(album);

const langLabel = (lang: 'en' | 'el') => (lang === 'el' ? 'Ελληνικά' : 'English');

// The on-page `description` is long-form prose; Google truncates around 160 chars, so prefer
// the purpose-written `seoDescription` when the album supplies one.
const metaDescription = seoDescription ?? description;
const url = `/albums/${album.id}`;
---

<MainLayout title={title} description={metaDescription} image={cover?.src.src}>
	<JsonLd
		slot="head"
		schema={imageGallerySchema(Astro.site, {
			url,
			name: title,
			description: metaDescription,
			images: images.map((image) => ({
				contentUrl: image.src.src,
				name: imageAlt(image),
				description: image.description || undefined,
			})),
		})}
	/>
	<JsonLd
		slot="head"
		schema={breadcrumbSchema(Astro.site, [
			{ name: 'Home', url: '/' },
			{ name: 'Albums', url: '/albums' },
			{ name: title, url },
		])}
	/>

	<!-- Split hero: cover image beside the album title -->
	<section class="pt-28 pb-8 md:pt-32">
		<div class="container-custom">
			{
				cover ? (
					<div class="grid items-center gap-10 md:grid-cols-2 md:gap-14">
						<Image
							src={cover.src}
							quality={90}
							format="webp"
							width={cover.src.width}
							height={cover.src.height}
							alt={cover.title}
							class="h-auto w-full rounded-lg shadow-lg"
						/>
						<div>
							<h3 class="eyebrow text-xl" style="color: hsl(var(--brand-strong));">Album</h3>
							<h1 class="mt-4 text-4xl font-bold md:text-6xl">{title}</h1>
							<p class="mt-6 text-lg text-gray-600 md:text-xl">{description}</p>
						</div>
					</div>
				) : (
					<div class="mx-auto max-w-2xl text-center">
						<h3 class="eyebrow text-xl" style="color: hsl(var(--brand-strong));">Album</h3>
						<h1 class="mt-4 text-4xl font-bold md:text-6xl">{title}</h1>
						<p class="mt-6 text-lg text-gray-600 md:text-xl">{description}</p>
					</div>
				)
			}
		</div>
	</section>

	<!-- Videos -->
	{
		videos.length > 0 && (
			<section class="py-16">
				<div class="container-custom max-w-5xl">
					<div class="mb-10 text-center">
						<h2 class="text-3xl font-bold md:text-4xl">Video</h2>
					</div>
					<div class={videos.length === 1 ? 'mx-auto max-w-2xl' : 'grid gap-8 md:grid-cols-2'}>
						{videos.map((video) => (
							<figure>
								<YouTubeLink url={video.url} title={video.title ?? `${title} — ${langLabel(video.lang)}`} />
								{videos.length > 1 && (
									<figcaption class="mt-3 text-base uppercase tracking-[0.18em] text-gray-500">
										{video.title ?? langLabel(video.lang)}
									</figcaption>
								)}
							</figure>
						))}
					</div>
				</div>
			</section>
		)
	}

	<!-- PDF-flip links -->
	{
		pdfs.length > 0 && (
			<section class="pb-16">
				<div class="container-custom text-center">
					<h2 class="mb-8 text-3xl font-bold md:text-4xl">Publication</h2>
					<div class="flex flex-wrap justify-center gap-6">
						{pdfs.map((pdf) => {
							const label = pdf.label ?? `Flip through the album (${langLabel(pdf.lang)})`;
							const book = pdf.flipbook ? flipbooks[pdf.flipbook] : undefined;
							if (pdf.flipbook && book) {
								return (
									<Flipbook
										id={pdf.flipbook}
										pages={book.pages}
										width={book.width}
										height={book.height}
										label={label}
									/>
								);
							}
							return pdf.url ? (
								<a
									href={pdf.url}
									target="_blank"
									rel="noopener"
									class="cta-link text-xl border border-gray-300 px-8 py-4 text-gray-900 hover:text-brand font-weight-bold"
								>
									{label}
									<span class="cta-arrow">&rarr;</span>
								</a>
							) : null;
						})}
					</div>
				</div>
			</section>
		)
	}

	<!-- Texts (EN / EL blocks authored in the album MDX body) — side by side -->
	<section class="py-16">
		<div class="container-custom grid gap-12 md:grid-cols-2 md:gap-16">
			<Content components={{ AlbumText }} />
		</div>
	</section>

	<!-- Photo grid -->
	{
		images.length > 0 && (
			<section class="pb-16">
				<div class="w-full px-4 sm:px-8 lg:px-16">
					<PhotoGrid images={images} />
				</div>
			</section>
		)
	}
</MainLayout>
