---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedGallery from '../components/FeaturedGallery.astro';
import AlbumsShowcase from '../components/AlbumsShowcase.astro';
import JsonLd from '../components/JsonLd.astro';
import { webSiteSchema } from '../data/jsonld';

const description =
	'Photography by Paul Isaris, an artist from Athens working across image, writing and music. Explore the NOPLACE and Underlight series — beyond the surface.';
---

<MainLayout
	fullTitle="Paul Isaris — Photographer & Visual Artist, Athens"
	description={description}
>
	<JsonLd slot="head" schema={webSiteSchema(Astro.site)} />

	<Hero />

	<section class="featured-section py-24">
		<FeaturedGallery />
	</section>

	<section id="albums" class="scroll-mt-[65px] py-24">
		<div class="container-custom">
			<div class="mb-14 text-center">
				<h3 class="eyebrow text-2xl" style="color: hsl(var(--brand-strong));">Curated Projects</h3>
				<h2 class="mt-3 text-3xl font-bold md:text-4xl">Albums</h2>
			</div>
			<AlbumsShowcase />
		</div>
	</section>
</MainLayout>
