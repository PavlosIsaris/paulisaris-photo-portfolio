---
// A single language's text block for an album, used inside album MDX bodies:
//   <AlbumText lang="en">…markdown…</AlbumText>
// Renders a small labeled heading above the prose so EN/EL variants read clearly.
interface Props {
	lang: 'en' | 'el';
}

const { lang } = Astro.props;

const label = lang === 'el' ? 'Ελληνικά' : 'English';
---

<div class="album-text" lang={lang}>
	<h3 class="eyebrow mb-4" style="color: hsl(var(--brand-strong));">{label}</h3>
	<div class="prose prose-lg lg:prose-xl max-w-none text-gray-700">
		<slot />
	</div>
</div>
