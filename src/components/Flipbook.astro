---
// A "Publication" trigger button + a full-screen <dialog> that hosts the StPageFlip flipbook
// for one album PDF (one language). The page images live under public/flipbooks/<id>/ and are
// generated by `npm run flipbook`; the client logic is in src/scripts/flipbook.ts.
interface Props {
	id: string; // flipbook id == folder under public/flipbooks/<id>
	pages: number; // total page count (from src/data/flipbooks.json)
	width: number; // single-page width in px (aspect ratio source)
	height: number; // single-page height in px
	label: string; // button text
}

const { id, pages, width, height, label } = Astro.props;
const base = import.meta.env.BASE_URL;
const dialogId = `flipbook-dialog-${id}`;
const mountId = `flipbook-mount-${id}`;
---

<button
	type="button"
	class="cta-link border border-gray-300 px-8 py-4 text-xl text-gray-900 hover:text-brand"
	data-flipbook-trigger={dialogId}
	aria-haspopup="dialog"
>
	{label}
	<span class="cta-arrow">&rarr;</span>
</button>

<dialog
	id={dialogId}
	class="flipbook-dialog"
	data-flipbook
	data-id={id}
	data-pages={pages}
	data-width={width}
	data-height={height}
	data-base={base}
	closedby="any"
	aria-label={`${label} — flipbook`}
>
	<div class="flipbook-shell">
		<button type="button" class="flipbook-close" data-flipbook-close aria-label="Close flipbook">
			<span aria-hidden="true">&times;</span>
		</button>

		<div class="flipbook-stage">
			<button
				type="button"
				class="flipbook-nav flipbook-prev"
				data-flipbook-prev
				aria-label="Previous page"
			>
				<span aria-hidden="true">&lsaquo;</span>
			</button>

			<div id={mountId} class="flipbook-mount" data-flipbook-book></div>

			<button
				type="button"
				class="flipbook-nav flipbook-next"
				data-flipbook-next
				aria-label="Next page"
			>
				<span aria-hidden="true">&rsaquo;</span>
			</button>
		</div>

		<p class="flipbook-status" data-flipbook-status aria-live="polite"></p>
	</div>
</dialog>

<script>
	import '../scripts/flipbook';
</script>

<style>
	.flipbook-dialog {
		width: 100vw;
		height: 100dvh;
		max-width: 100vw;
		max-height: 100dvh;
		margin: 0;
		padding: 0;
		border: none;
		background: transparent;
		overflow: hidden;
		color: #f5f5f4;
	}

	.flipbook-dialog::backdrop {
		background: rgba(12, 12, 14, 0.85);
		backdrop-filter: blur(4px);
	}

	.flipbook-shell {
		box-sizing: border-box;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		width: 100%;
		height: 100%;
		padding: clamp(0.75rem, 3vw, 2rem);
	}

	.flipbook-stage {
		position: relative;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		flex: 1 1 auto;
		min-height: 0;
	}

	.flipbook-mount {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	/* StPageFlip injects an absolutely-positioned block; keep it centered within the mount. */
	.flipbook-mount :global(.stf__wrapper) {
		margin: 0 auto;
	}

	.flipbook-close,
	.flipbook-nav {
		position: absolute;
		z-index: 2;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid rgba(245, 245, 244, 0.4);
		border-radius: 9999px;
		background: rgba(20, 20, 22, 0.55);
		color: #f5f5f4;
		cursor: pointer;
		transition:
			background-color 0.2s ease,
			border-color 0.2s ease,
			transform 0.2s ease;
	}

	.flipbook-close:hover,
	.flipbook-nav:hover {
		background: rgba(40, 40, 44, 0.85);
		border-color: rgba(245, 245, 244, 0.8);
	}

	.flipbook-close {
		top: clamp(0.5rem, 2vw, 1.25rem);
		right: clamp(0.5rem, 2vw, 1.25rem);
		width: 2.75rem;
		height: 2.75rem;
		font-size: 1.75rem;
		line-height: 1;
	}

	.flipbook-nav {
		top: 50%;
		transform: translateY(-50%);
		width: 3rem;
		height: 3rem;
		font-size: 2rem;
		line-height: 1;
	}

	.flipbook-nav:hover {
		transform: translateY(-50%) scale(1.05);
	}

	.flipbook-prev {
		left: clamp(0.25rem, 1.5vw, 1rem);
	}

	.flipbook-next {
		right: clamp(0.25rem, 1.5vw, 1rem);
	}

	.flipbook-status {
		font-size: 0.85rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(245, 245, 244, 0.75);
		min-height: 1.2em;
	}

	/* Entry/exit animation for the dialog + backdrop (progressive enhancement). */
	.flipbook-dialog[open] {
		opacity: 1;
		@starting-style {
			opacity: 0;
		}
	}

	.flipbook-dialog {
		opacity: 0;
		transition:
			opacity 0.25s ease,
			display 0.25s ease allow-discrete,
			overlay 0.25s ease allow-discrete;
	}

	@media (prefers-reduced-motion: reduce) {
		.flipbook-dialog {
			transition-duration: 0.01s;
		}
	}
</style>
