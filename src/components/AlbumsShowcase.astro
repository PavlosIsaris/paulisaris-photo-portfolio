---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getImageByPath } from '../data/imageStore';

const base = import.meta.env.BASE_URL;

// Draft albums are visible in dev but hidden from production builds (mirrors posts).
const albums = (
	await getCollection('albums', ({ data }) => (import.meta.env.PROD ? !data.draft : true))
).sort((a, b) => a.data.order - b.data.order);

const cards = await Promise.all(
	albums.map(async (album) => ({
		album,
		cover: await getImageByPath(album.data.cover),
	})),
);
---

{
	cards.length > 0 && (
		<div class="grid gap-8 sm:grid-cols-2">
			{cards.map(({ album, cover }) => (
				<a
					href={`${base}albums/${album.id}`}
					class="group flex flex-col rounded-lg border border-gray-200 bg-gray-50 p-5 transition-shadow duration-300 hover:shadow-md"
				>
					<div class="overflow-hidden rounded-sm">
						{cover && (
							<Image
								src={cover.src}
								quality={90}
								format="webp"
								width={cover.src.width}
								height={cover.src.height}
								alt={cover.title}
								class="h-72 w-full object-contain transition-transform duration-500 group-hover:scale-[1.02]"
							/>
						)}
					</div>
					<h3 class="mt-6 text-3xl font-bold transition-colors group-hover:text-brand">
						{album.data.title}
					</h3>
					<p class="mb-6 mt-3 text-lg text-gray-600">{album.data.description}</p>
					<span class="mt-auto inline-block self-start bg-brand px-6 py-3 text-sm font-medium uppercase tracking-[0.18em] text-white transition-colors duration-300 hover:bg-[hsl(var(--brand-strong))]">
						View Album
					</span>
				</a>
			))}
		</div>
	)
}
