---
import siteConfig from '../../site.config.mjs';
import SocialIcon from './SocialIcon.astro';

const year = new Date().getFullYear();
const owner = siteConfig.owner;
const socialLinks = siteConfig.socialLinks;
const base = import.meta.env.BASE_URL;

const menuItems = [
	{ name: 'Gallery', link: `${base}collections` },
	{ name: 'About', link: `${base}about` },
];
---

<footer class="mt-auto bg-neutral-900 text-gray-300">
	<div class="container mx-auto py-16">
		<div class="flex flex-col md:flex-row md:justify-between gap-12 md:items-start">
			<!-- Nav -->
			<nav class="flex flex-col items-center md:items-start gap-3">
				{
					menuItems.map((item) => (
						<a
							href={item.link}
							class="text-sm uppercase tracking-[0.18em] font-playfair text-gray-300 hover:text-brand transition-colors duration-300"
						>
							{item.name}
						</a>
					))
				}
			</nav>

			<!-- Get in touch -->
			<div class="flex flex-col items-center md:items-end gap-4">
				<p class="eyebrow">Get in Touch</p>
				<div class="flex gap-5">
					{
						socialLinks.map((socialLink) => (
							<SocialIcon
								socialLink={socialLink}
								size={20}
								class="text-gray-400 hover:text-brand"
							/>
						))
					}
				</div>
			</div>
		</div>

		<div class="mt-14 pt-8 border-t border-white/10 text-center text-xs text-gray-400">
			© {year}
			{owner}. All rights reserved.
		</div>
	</div>
</footer>
