---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import Footer from '../components/Footer.astro';
import NavBar from '../components/NavBar.astro';
import { getHeroImage } from '../data/imageStore';

interface Props {
	title?: string;
	description?: string;
	image?: string; // absolute or root-relative URL for social previews
}

const { title, description, image } = Astro.props;

const owner = siteConfig.owner;
const favicon = siteConfig.favicon;
const base = import.meta.env.BASE_URL;

const pageTitle = title ? `${title} · ${owner}` : owner;
const pageDescription =
	description ?? `Photography by ${owner} — collections, galleries and posts.`;
const siteURL = Astro.site?.href?.replace(/\/$/, '');

// Site-wide fallback when a page passes no `image`: an explicit URL is used as-is,
// anything else is looked up as a gallery-relative path (and getHeroImage itself
// falls back to heroImage / the first featured photo).
const configImage = siteConfig.seoImage || siteConfig.heroImage;
const fallbackImage = /^(https?:\/\/|\/)/.test(configImage)
	? configImage
	: (await getHeroImage(configImage))?.src.src;
const pageImage = image ?? fallbackImage;

// Absolute canonical + social image URLs require `site` to be set in astro.config.
const canonicalURL = Astro.site ? `${siteURL}${Astro.url.pathname}` : undefined;
const socialImage =
	pageImage && Astro.site
		? pageImage.match(/^https?:\/\//)
			? pageImage
			: `${siteURL}/${pageImage.replace(/^\//, '')}`
		: pageImage;
---

<html lang="en" class="h-full">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${base}${favicon}`} />
		<link rel="icon" type="image/png" sizes="32x32" href={`${base}favicon-32.png`} />
		<link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- Load fonts non-blocking: fetch as a preload, then flip to a stylesheet once ready. -->
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
			onload="this.onload=null;this.rel='stylesheet'"
		/>
		<noscript>
			<link
				rel="stylesheet"
				href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap"
			/>
		</noscript>

		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={pageDescription} />
		{canonicalURL && <link rel="canonical" href={canonicalURL} />}

		<!-- Open Graph / social sharing -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={pageDescription} />
		{canonicalURL && <meta property="og:url" content={canonicalURL} />}
		{socialImage && <meta property="og:image" content={socialImage} />}
		{socialImage && <meta property="og:image:alt" content={pageTitle} />}
		<meta name="twitter:card" content={socialImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={pageDescription} />
		{socialImage && <meta name="twitter:image" content={socialImage} />}
	</head>
	<body>
		<NavBar />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>

<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
