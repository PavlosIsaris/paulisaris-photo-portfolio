---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';
import MainLayout from './MainLayout.astro';

interface Props {
	title: string;
	description: string;
	date: Date;
	tags?: string[];
	cover?: ImageMetadata;
	coverAlt?: string;
}

const { title, description, date, tags = [], cover, coverAlt } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(date);
---

<MainLayout title={title} description={description} image={cover?.src}>
	<article class="pt-32 pb-20">
		<div class="container-custom">
			<header class="max-w-3xl mx-auto text-center mb-10">
				<p class="text-sm uppercase tracking-widest text-gray-500 mb-4">
					<time datetime={date.toISOString()}>{formattedDate}</time>
				</p>
				<h1 class="text-4xl md:text-5xl font-bold mb-6">{title}</h1>
				<p class="text-lg text-gray-600">{description}</p>
				{
					tags.length > 0 && (
						<ul class="flex flex-wrap gap-2 justify-center mt-6">
							{tags.map((tag) => (
								<li class="px-3 py-1 text-sm border border-gray-200 text-gray-600">
									{tag}
								</li>
							))}
						</ul>
					)
				}
			</header>

			{
				cover && (
					<Image
						src={cover}
						alt={coverAlt ?? title}
						widths={[480, 800, 1200, 1600]}
						sizes="(max-width: 768px) 100vw, 900px"
						format="webp"
						loading="eager"
						class="w-full h-auto max-w-4xl mx-auto rounded-lg shadow-lg mb-12"
					/>
				)
			}

			<div class="prose lg:prose-lg max-w-2xl mx-auto text-gray-700">
				<slot />
			</div>

			<div class="max-w-2xl mx-auto mt-16 pt-8 border-t border-gray-200">
				<a href={`${import.meta.env.BASE_URL}posts`} class="text-gray-600 hover:text-black">
					← Back to all posts
				</a>
			</div>
		</div>
	</article>
</MainLayout>
